{
  "version": 2,
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    },
    "api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/lando", "destination": "/lando/index.html" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
